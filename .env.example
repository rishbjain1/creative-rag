# LLM — provider-agnostic (OpenAI-compatible). Defaults to Anthropic.
CRAG_LLM_BASE_URL=https://api.anthropic.com/v1
CRAG_LLM_MODEL=claude-opus-4-8
CRAG_LLM_API_KEY=sk-ant-...          # or set ANTHROPIC_API_KEY

# API auth — if set, POST /query requires header X-API-Key with this value.
CRAG_API_KEY=

# Corpus + index (optional overrides)
# CRAG_CORPUS_ROOT=~/AI content
# CRAG_INDEX_DIR=./index

# Local models (PyTorch / sentence-transformers) — optional overrides
# CRAG_EMBED_MODEL=BAAI/bge-small-en-v1.5
# CRAG_RERANK_MODEL=BAAI/bge-reranker-base
